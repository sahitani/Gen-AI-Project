        "# Cell 3 — The Agent Loop with Human in the Loop\n",
        "\n",
        "# Map tool names to actual Python functions\n",
        "tool_map = {\n",
        "    \"check_order_details\": check_order_details,\n",
        "    \"classify_hold\": classify_hold,\n",
        "    \"send_escalation\": send_escalation,\n",
        "    \"update_dashboard\": update_dashboard,\n",
        "    \"request_credit_increase\": request_credit_increase\n",
        "}\n",
        "\n",
        "# Actions that require human approval before executing\n",
        "HUMAN_APPROVAL_REQUIRED = [\n",
        "    \"send_escalation\",\n",
        "    \"request_credit_increase\"\n",
        "]\n",
        "\n",
        "def run_agent(task):\n",
        "    print(f\"TASK: {task}\")\n",
        "    print(\"=\" * 60)\n",
        "\n",
        "    messages = [{\"role\": \"user\", \"content\": task}]\n",
        "    step = 1\n",
        "\n",
        "    # Agent loop — keeps running until Claude says done\n",
        "    while True:\n",
        "        print(f\"\\nStep {step} — Sending to Claude...\")\n",
        "\n",
        "        # Send task + tools to Claude\n",
        "        response = client.messages.create(\n",
        "            model=\"claude-sonnet-4-6\",\n",
        "            max_tokens=1024,\n",
        "            tools=tools,\n",
        "            messages=messages\n",
        "        )\n",
        "\n",
        "        print(f\"Claude stop reason: {response.stop_reason}\")\n",
        "\n",
        "        # If Claude is done — print final answer and exit loop\n",
        "        if response.stop_reason == \"end_turn\":\n",
        "            final_answer = response.content[0].text\n",
        "            print(\"\\n\" + \"=\" * 60)\n",
        "            print(\"AGENT FINAL ANSWER:\")\n",
        "            print(final_answer)\n",
        "            print(\"=\" * 60)\n",
        "            break\n",
        "\n",
        "        # If Claude wants to use a tool\n",
        "        if response.stop_reason == \"tool_use\":\n",
        "\n",
        "            # Add Claude's response to message history\n",
        "            messages.append({\n",
        "                \"role\": \"assistant\",\n",
        "                \"content\": response.content\n",
        "            })\n",
        "\n",
        "            # Process each tool Claude wants to call\n",
        "            tool_results = []\n",
        "\n",
        "            for block in response.content:\n",
        "                if block.type == \"tool_use\":\n",
        "                    tool_name = block.name\n",
        "                    tool_input = block.input\n",
        "\n",
        "                    print(f\"\\nClaude wants to call: {tool_name}\")\n",
        "                    print(f\"With inputs: {json.dumps(tool_input, indent=2)}\")\n",
        "\n",
        "                    # HUMAN IN THE LOOP — check if approval needed\n",
        "                    if tool_name in HUMAN_APPROVAL_REQUIRED:\n",
        "                        print(\"\\n⚠️  HUMAN APPROVAL REQUIRED\")\n",
        "                        print(f\"Claude wants to execute: {tool_name}\")\n",
        "                        print(f\"Inputs: {json.dumps(tool_input, indent=2)}\")\n",
        "                        approval = input(\"\\nDo you approve this action? (yes/no): \")\n",
        "\n",
        "                        if approval.lower() != \"yes\":\n",
        "                            tool_result = {\n",
        "                                \"status\": \"REJECTED\",\n",
        "                                \"message\": \"Action rejected by human supervisor\"\n",
        "                            }\n",
        "                            print(\"Action REJECTED ✗\")\n",
        "                        else:\n",
        "                            # Execute the tool\n",
        "                            tool_result = tool_map[tool_name](**tool_input)\n",
        "                            print(\"Action APPROVED and executed ✓\")\n",
        "                    else:\n",
        "                        # No approval needed — execute automatically\n",
        "                        tool_result = tool_map[tool_name](**tool_input)\n",
        "                        print(f\"Tool executed automatically ✓\")\n",
        "                        print(f\"Result: {json.dumps(tool_result, indent=2)}\")\n",
        "\n",
        "                    tool_results.append({\n",
        "                        \"type\": \"tool_result\",\n",
        "                        \"tool_use_id\": block.id,\n",
        "                        \"content\": json.dumps(tool_result)\n",
        "                    })\n",
        "\n",
        "            # Send tool results back to Claude\n",
        "            messages.append({\n",
        "                \"role\": \"user\",\n",
        "                \"content\": tool_results\n",
        "            })\n",
        "\n",
        "            step += 1\n",
        "\n",
        "    return messages\n",
        "\n",
        "\n",
        "# Run the agent on a real order\n",
        "run_agent(\"Please handle order ORD001 — check it, classify the hold priority, and take all necessary actions.\")"
