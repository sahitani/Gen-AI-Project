        "# Cell 1 — Define the Agent's Tools\n",
        "# These are real Python functions the LLM can call\n",
        "\n",
        "def check_order_details(order_id):\n",
        "    \"\"\"Look up order details from the system\"\"\"\n",
        "    # In real production this would query a database\n",
        "    # We are using fake data for learning\n",
        "    orders = {\n",
        "        \"ORD001\": {\n",
        "            \"order_id\": \"ORD001\",\n",
        "            \"customer\": \"Tata Consultancy Services\",\n",
        "            \"customer_tier\": \"Top 20\",\n",
        "            \"order_value\": 250000,\n",
        "            \"currency\": \"USD\",\n",
        "            \"region\": \"APJ\",\n",
        "            \"hold_reason\": \"Credit limit exceeded by 12%\",\n",
        "            \"hold_duration_days\": 5,\n",
        "            \"credit_breach_percent\": 12\n",
        "        },\n",
        "        \"ORD002\": {\n",
        "            \"order_id\": \"ORD002\",\n",
        "            \"customer\": \"Infosys Limited\",\n",
        "            \"customer_tier\": \"Standard\",\n",
        "            \"order_value\": 15000,\n",
        "            \"currency\": \"USD\",\n",
        "            \"region\": \"APJ\",\n",
        "            \"hold_reason\": \"Minor address formatting error\",\n",
        "            \"hold_duration_days\": 1,\n",
        "            \"credit_breach_percent\": 0\n",
        "        }\n",
        "    }\n",
        "    return orders.get(order_id, {\"error\": \"Order not found\"})\n",
        "\n",
        "\n",
        "def classify_hold(order_details):\n",
        "    \"\"\"Classify hold priority based on order details\"\"\"\n",
        "    priority = \"LOW\"\n",
        "    reasons = []\n",
        "\n",
        "    if order_details.get(\"credit_breach_percent\", 0) > 5:\n",
        "        priority = \"HIGH\"\n",
        "        reasons.append(\"Credit breach exceeds 5%\")\n",
        "\n",
        "    if order_details.get(\"order_value\", 0) > 100000:\n",
        "        priority = \"HIGH\"\n",
        "        reasons.append(\"Order value exceeds USD 100,000\")\n",
        "\n",
        "    if order_details.get(\"customer_tier\") == \"Top 20\":\n",
        "        priority = \"HIGH\"\n",
        "        reasons.append(\"Customer is Top 20 account\")\n",
        "\n",
        "    if order_details.get(\"hold_duration_days\", 0) > 3:\n",
        "        priority = \"HIGH\"\n",
        "        reasons.append(\"Hold duration exceeds 3 days\")\n",
        "\n",
        "    return {\n",
        "        \"priority\": priority,\n",
        "        \"reasons\": reasons,\n",
        "        \"order_id\": order_details.get(\"order_id\")\n",
        "    }\n",
        "\n",
        "\n",
        "def send_escalation(order_id, priority, reason, escalate_to):\n",
        "    \"\"\"Send escalation notification\"\"\"\n",
        "    return {\n",
        "        \"status\": \"SUCCESS\",\n",
        "        \"message\": f\"Escalation sent to {escalate_to}\",\n",
        "        \"order_id\": order_id,\n",
        "        \"priority\": priority,\n",
        "        \"reason\": reason,\n",
        "        \"escalated_to\": escalate_to,\n",
        "        \"response_sla\": \"24 hours\"\n",
        "    }\n",
        "\n",
        "\n",
        "def update_dashboard(order_id, status, priority):\n",
        "    \"\"\"Update order management dashboard\"\"\"\n",
        "    return {\n",
        "        \"status\": \"SUCCESS\",\n",
        "        \"message\": f\"Dashboard updated for order {order_id}\",\n",
        "        \"new_status\": status,\n",
        "        \"priority_flag\": priority\n",
        "    }\n",
        "\n",
        "\n",
        "def request_credit_increase(order_id, customer, increase_percent, approver):\n",
        "    \"\"\"Request temporary credit limit increase\"\"\"\n",
        "    return {\n",
        "        \"status\": \"PENDING_APPROVAL\",\n",
        "        \"message\": f\"Credit increase request submitted to {approver}\",\n",
        "        \"order_id\": order_id,\n",
        "        \"customer\": customer,\n",
        "        \"increase_requested\": f\"{increase_percent}%\",\n",
        "        \"approver\": approver,\n",
        "        \"expected_response\": \"4 hours\"\n",
        "    }\n",
        "\n",
        "\n",
        "print(\"Tools defined ✓\")\n",
        "print(\"Available tools:\")\n",
        "print(\"  1. check_order_details()\")\n",
        "print(\"  2. classify_hold()\")\n",
        "print(\"  3. send_escalation()\")\n",
        "print(\"  4. update_dashboard()\")\n",
        "print(\"  5. request_credit_increase()\")"
